---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Koozo Mart — Épicerie japonaise & coréenne',
  description = 'Koozo Mart, une épicerie dédiée aux produits alimentaires et du quotidien venus du Japon et de la Corée.',
} = Astro.props;

const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/boutiques', label: 'Boutiques' },
  { href: '/about', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500&family=Noto+Serif+JP:wght@400;500&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-ivory text-ink antialiased">
    <header class="border-b border-ink-line/70">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 py-4 sm:h-20 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-0">
        <a href="/" class="flex items-center gap-3 self-center sm:self-auto">
          <img src="/logo.jpg" alt="Koozo Mart" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full object-cover bg-ink" />
          <span class="font-serif text-lg sm:text-xl tracking-wide">Koozo Mart</span>
        </a>
        <nav class="flex justify-center gap-5 sm:gap-8 text-sm overflow-x-auto whitespace-nowrap -mx-5 px-5 sm:mx-0 sm:px-0">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'transition-colors shrink-0',
                pathname === item.href
                  ? 'text-ink border-b border-gold pb-1'
                  : 'text-ink-soft hover:text-ink',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-5 sm:px-6 py-10 md:py-16">
      <slot />
    </main>

    <footer class="border-t border-ink-line/70 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <img src="/logo.jpg" alt="" class="h-8 w-8 rounded-full object-cover bg-ink" />
          <span class="font-serif">Koozo Mart</span>
        </div>
        <div class="flex items-center gap-5 text-sm text-ink-mute">
          <a
            href="https://www.instagram.com/koozomart/"
            target="_blank"
            rel="noopener"
            class="hover:text-gold transition-colors tracking-wider"
            aria-label="Koozo Mart sur Instagram"
          >
            Instagram
          </a>
          <a
            href="mailto:contact@koozomart.com"
            class="hover:text-gold transition-colors"
          >
            contact@koozomart.com
          </a>
        </div>
        <p class="text-sm text-ink-mute">
          &copy; Koozo Mart — depuis 2014
        </p>
      </div>
    </footer>
  </body>
</html>

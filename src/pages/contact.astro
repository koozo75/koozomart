---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact · Koozo Mart">
  <section class="max-w-2xl">
    <p class="text-xs tracking-[0.4em] text-gold mb-4">CONTACT</p>
    <h1 class="font-serif text-4xl md:text-5xl mb-12">Nous contacter</h1>

    <dl class="space-y-8">
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-10 border-b border-ink-line/70 pb-6">
        <dt class="text-xs tracking-[0.3em] text-gold sm:w-36">ADRESSE</dt>
        <dd class="text-ink-soft">À compléter</dd>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-10 border-b border-ink-line/70 pb-6">
        <dt class="text-xs tracking-[0.3em] text-gold sm:w-36">HORAIRES</dt>
        <dd class="text-ink-soft">Du lundi au dimanche · 10h00 – 20h00</dd>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-10 border-b border-ink-line/70 pb-6">
        <dt class="text-xs tracking-[0.3em] text-gold sm:w-36">TÉLÉPHONE</dt>
        <dd class="text-ink-soft">À compléter</dd>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-10 border-b border-ink-line/70 pb-6">
        <dt class="text-xs tracking-[0.3em] text-gold sm:w-36">EMAIL</dt>
        <dd class="text-ink-soft">
          <a href="mailto:hello@koozomart.com" class="underline underline-offset-4 decoration-gold hover:text-ink">
            hello@koozomart.com
          </a>
        </dd>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-10">
        <dt class="text-xs tracking-[0.3em] text-gold sm:w-36">RÉSEAUX</dt>
        <dd class="text-ink-soft">Instagram · à compléter</dd>
      </div>
    </dl>
  </section>
</Layout>

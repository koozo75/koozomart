---
import Layout from '../layouts/Layout.astro';
import { boutiques } from '../data/boutiques';

const HOURS = '10h30 — 20h30';
const HOURS_NOTE = 'Du lundi au dimanche';
---

<Layout title="Boutiques · Koozo Mart" description="Nos boutiques Koozo Mart à Paris et Montrouge.">
  <section class="mb-14">
    <p class="text-xs tracking-[0.4em] text-gold mb-4">BOUTIQUES</p>
    <h1 class="font-serif text-4xl md:text-5xl">Nos boutiques</h1>
    <p class="mt-5 text-ink-soft max-w-xl leading-relaxed">
      Trois adresses à Paris et en proche banlieue, pour retrouver nos produits japonais et coréens au plus près de chez vous.
    </p>
    <p class="mt-2 text-sm text-ink-mute">
      Horaires&nbsp;: <span class="text-ink-soft">{HOURS}</span> · {HOURS_NOTE}
    </p>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
    {boutiques.map((b) => {
      const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(b.mapQuery)}&output=embed`;
      const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(b.mapQuery)}`;
      const isSoon = b.status === 'bientot';
      return (
        <article id={b.slug} class="group border border-ink-line/70 overflow-hidden">
          <div class="aspect-[16/10] bg-ink-line/30 relative">
            <iframe
              src={mapSrc}
              title={`Carte — ${b.name}`}
              class="w-full h-full border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
            {isSoon && (
              <div class="absolute top-3 right-3 bg-gold text-ink text-xs tracking-widest px-3 py-1">
                BIENTÔT
              </div>
            )}
          </div>
          <div class="p-6">
            <h2 class="font-serif text-2xl">{b.name}</h2>
            <p class="mt-3 text-ink-soft">{b.address}</p>
            <p class="text-ink-soft">{b.postcode} {b.city}</p>
            {b.metro && (
              <p class="mt-2 text-sm text-ink-mute">Métro · {b.metro}</p>
            )}
            <p class="mt-4 text-sm text-ink-mute">{HOURS} · {HOURS_NOTE}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={mapLink}
                target="_blank"
                rel="noopener"
                class="inline-block px-5 py-2 bg-ink text-ivory text-xs tracking-widest hover:bg-gold hover:text-ink transition-colors"
              >
                ITINÉRAIRE
              </a>
              {isSoon && (
                <span class="inline-block px-5 py-2 border border-gold text-gold text-xs tracking-widest">
                  OUVERTURE PROCHAINE
                </span>
              )}
            </div>
          </div>
        </article>
      );
    })}
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { categories } from '../data/categories';
import { boutiques } from '../data/boutiques';

const deliverooShops = boutiques.filter((b) => b.deliveroo);
---

<Layout>
  <section class="py-10 md:py-24">
    <p class="text-xs tracking-[0.4em] text-gold mb-5 md:mb-6">KOOZO MART</p>
    <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl leading-[1.1] tracking-tight">
      Les saveurs du<br class="hidden sm:inline" />
      Japon &amp; de la Corée,<br class="hidden sm:inline" />
      <span class="italic text-ink-soft">au quotidien.</span>
    </h1>
    <p class="mt-8 md:mt-10 max-w-xl text-ink-soft leading-relaxed text-base md:text-lg">
      Une sélection d’épicerie, de snacks et d’objets du quotidien,
      rapportés avec soin depuis les rayons de Tokyo et les ruelles de Séoul.
    </p>
    <div class="mt-8 md:mt-10 flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4">
      <a
        href="/products"
        class="inline-block text-center px-7 py-3 bg-ink text-ivory text-sm tracking-wider hover:bg-gold hover:text-ink transition-colors"
      >
        Découvrir les produits
      </a>
      <a
        href="/about"
        class="inline-block text-center px-7 py-3 border border-ink-line text-sm tracking-wider hover:border-ink transition-colors"
      >
        À propos
      </a>
    </div>
  </section>

  <section class="border-t border-ink-line/70 pt-12 md:pt-16 mt-4 md:mt-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-10 md:mb-12">
      <div>
        <p class="text-xs tracking-[0.4em] text-gold mb-3">NOS RAYONS</p>
        <h2 class="font-serif text-3xl md:text-4xl">Ce que vous trouverez chez nous</h2>
      </div>
      <a href="/boutiques" class="text-sm text-ink-mute hover:text-ink">Venir en boutique →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-8">
      {categories.map((c) => (
        <article class="group">
          <div class="aspect-square bg-ink-line/30 overflow-hidden">
            <img
              src={c.image}
              alt={c.name}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="mt-3 md:mt-4">
            <h3 class="font-serif text-base md:text-lg leading-tight">{c.name}</h3>
            <p class="mt-1 text-xs tracking-widest text-gold">{c.subtitle}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-3 gap-8 border-t border-ink-line/70 pt-12 md:pt-16">
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">ORIGINE</p>
      <p class="font-serif text-xl">Direct du Japon & de la Corée</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Des produits choisis sur place, chez les marques que nous aimons vraiment.
      </p>
    </div>
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">SÉLECTION</p>
      <p class="font-serif text-xl">En petites séries</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Peu de références, mais chacune testée avant d’entrer en boutique.
      </p>
    </div>
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">QUOTIDIEN</p>
      <p class="font-serif text-xl">Pour la vie de tous les jours</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Pas des objets de vitrine — des choses que vous allez réellement utiliser.
      </p>
    </div>
  </section>

  <section class="mt-16 md:mt-24 border-t border-ink-line/70 pt-12 md:pt-16">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-10 md:mb-12">
      <div>
        <p class="text-xs tracking-[0.4em] text-gold mb-3">LIVRAISON</p>
        <h2 class="font-serif text-3xl md:text-4xl">Commandez à domicile</h2>
      </div>
      <p class="text-sm text-ink-mute max-w-xs">
        Disponible à Paris via Deliveroo depuis nos boutiques Bastille et République.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {deliverooShops.map((b) => (
        <a
          href={b.deliveroo}
          target="_blank"
          rel="noopener"
          class="group flex items-center justify-between p-6 md:p-8 border border-ink-line/70 hover:border-ink transition-colors"
        >
          <div>
            <p class="text-xs tracking-[0.3em] text-gold mb-2">DELIVEROO</p>
            <p class="font-serif text-xl md:text-2xl">{b.name}</p>
            <p class="mt-1 text-sm text-ink-mute">{b.address} · {b.postcode}</p>
          </div>
          <span class="text-ink-mute group-hover:text-ink text-2xl ml-4">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-16 md:mt-24 border-t border-ink-line/70 pt-12 md:pt-16">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-10 md:mb-12">
      <div>
        <p class="text-xs tracking-[0.4em] text-gold mb-3">INSTAGRAM</p>
        <h2 class="font-serif text-3xl md:text-4xl">Suivez-nous au quotidien</h2>
      </div>
      <a
        href="https://www.instagram.com/koozomart/"
        target="_blank"
        rel="noopener"
        class="text-sm text-ink-mute hover:text-ink"
      >
        @koozomart →
      </a>
    </div>
    <behold-widget feed-id="W1uWvRKBgBl3cIl4cQBx"></behold-widget>
  </section>
</Layout>

<script src="https://w.behold.so/widget.js" type="module" is:inline></script>

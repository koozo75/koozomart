---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';

const featured = products.slice(0, 3);
---

<Layout>
  <section class="relative py-16 md:py-28 overflow-hidden">
    <div class="absolute inset-x-0 bottom-0 h-48 seigaiha pointer-events-none"></div>

    <div class="relative">
      <p class="text-xs tracking-[0.4em] text-gold mb-6">KOOZO MART · 青海波</p>
      <h1 class="font-serif text-5xl md:text-7xl leading-[1.1] tracking-tight">
        Les saveurs du<br />
        Japon & de la Corée,<br />
        <span class="italic text-ink-soft">au quotidien.</span>
      </h1>
      <p class="mt-10 max-w-xl text-ink-soft leading-relaxed text-lg">
        Une sélection d’épicerie, de snacks et d’objets du quotidien,
        rapportés avec soin depuis les rayons de Tokyo et les ruelles de Séoul.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/products"
          class="inline-block px-7 py-3 bg-ink text-ivory text-sm tracking-wider hover:bg-gold hover:text-ink transition-colors"
        >
          Découvrir les produits
        </a>
        <a
          href="/about"
          class="inline-block px-7 py-3 border border-ink-line text-sm tracking-wider hover:border-ink transition-colors"
        >
          À propos
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-line/70 pt-16 mt-8">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs tracking-[0.4em] text-gold mb-3">SÉLECTION</p>
        <h2 class="font-serif text-3xl md:text-4xl">Nos produits phares</h2>
      </div>
      <a href="/products" class="text-sm text-ink-mute hover:text-ink">Voir tous →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {featured.map((p) => (
        <article class="group">
          <div class="aspect-square bg-ink-line/30 overflow-hidden">
            {p.image && (
              <img
                src={p.image}
                alt={p.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            )}
          </div>
          <div class="mt-4 flex items-baseline justify-between">
            <h3 class="font-serif text-lg">{p.name}</h3>
            <span class="text-xs tracking-widest text-gold">{p.origin}</span>
          </div>
          <p class="mt-1 text-sm text-ink-mute">{p.category}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-24 grid grid-cols-1 md:grid-cols-3 gap-8 border-t border-ink-line/70 pt-16">
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">ORIGINE</p>
      <p class="font-serif text-xl">Direct du Japon & de la Corée</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Des produits choisis sur place, chez les marques que nous aimons vraiment.
      </p>
    </div>
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">SÉLECTION</p>
      <p class="font-serif text-xl">En petites séries</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Peu de références, mais chacune testée avant d’entrer en boutique.
      </p>
    </div>
    <div>
      <p class="text-xs tracking-[0.4em] text-gold mb-3">QUOTIDIEN</p>
      <p class="font-serif text-xl">Pour la vie de tous les jours</p>
      <p class="mt-2 text-sm text-ink-soft leading-relaxed">
        Pas des objets de vitrine — des choses que vous allez réellement utiliser.
      </p>
    </div>
  </section>

  <section class="mt-24 border-t border-ink-line/70 pt-16">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs tracking-[0.4em] text-gold mb-3">INSTAGRAM</p>
        <h2 class="font-serif text-3xl md:text-4xl">Suivez-nous au quotidien</h2>
      </div>
      <a
        href="https://www.instagram.com/koozomart/"
        target="_blank"
        rel="noopener"
        class="text-sm text-ink-mute hover:text-ink"
      >
        @koozomart →
      </a>
    </div>
    <behold-widget feed-id="W1uWvRKBgBl3cIl4cQBx"></behold-widget>
  </section>
</Layout>

<script src="https://w.behold.so/widget.js" type="module" is:inline></script>
